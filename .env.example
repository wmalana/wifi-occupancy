# Mist API token (applies to all Mist sites)
MIST_API_TOKEN=your_mist_api_token_here

# Cisco credentials (shared across 9800 and 5505 sites unless overridden per site)
CISCO_USER=your_cisco_username
CISCO_PASS=your_cisco_password

# Optional: per-site credential overrides (site id uppercased + _USER / _PASS)
# CHICAGO_HQ_USER=admin
# CHICAGO_HQ_PASS=secret
